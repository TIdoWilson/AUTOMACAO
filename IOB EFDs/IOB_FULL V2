def main():
    print("====================================================")
    print("       ROBÔ IOB - DOWNLOAD EFDs + UPLOAD SPED       ")
    print("====================================================\n")

    driver = None

    try:
        # 1) Abrir Firefox e esperar login
        driver = abrir_firefox_e_aguardar_login()

        # 2) Perguntar se deve executar o Download EFDs v3
        print("\nEscolha o fluxo:")
        print("  1 - Executar 'Download EFDs v3' ANTES e depois zipar/enviar.")
        print("  2 - NÃO executar 'Download EFDs v3'; só zipar/enviar o que já existe na pasta.")
        opcao = input("\nDigite 1 ou 2 (padrão = 1): ").strip()

        if opcao == "2":
            executar_download = False
        else:
            executar_download = True

        # 3) Executar o script de download, se escolhido
        if executar_download:
            executar_download_efds()
        else:
            print("\n[INFO] Pulando a etapa de download. Usando apenas os arquivos já existentes em:")
            print("       ", DIR_EFDS)

        # 4) Criar ZIP com as EFDs
        zip_path = criar_zip_com_efds(DIR_EFDS)

        # 5) Navegar até Automação SPED e importar o ZIP
        acessar_painel_e_importar_sped(driver, zip_path)

        print("\n[FINALIZADO] Processo completo (ZIP gerado e enviado para Automação SPED).")
        print("             Acompanhe o processamento diretamente na tela da IOB.")

    except Exception as e:
        print("\n[ERRO FATAL] Ocorreu um erro durante a execução:")
        print(e)
        print("\nVerifique as mensagens acima (principalmente de seletores / elementos não encontrados).")

    finally:
        if driver is not None:
            try:
                driver.quit()
            except Exception:
                pass


if __name__ == "__main__":
    main()
