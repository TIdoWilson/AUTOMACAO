def tentar_preencher_login_iob(driver):
    """
    Tenta localizar os campos de usuário e senha e preenchê-los automaticamente.
    Você ainda precisa resolver o captcha / clicar em Entrar manualmente.
    """
    placeholders = {"SEU_LOGIN_AQUI", "SUA_SENHA_AQUI", "prencher", "preencher"}
    if not IOB_USUARIO or IOB_USUARIO in placeholders:
        print("[INFO] IOB_USUARIO não configurado. Login será totalmente manual.")
        return
    if not IOB_SENHA or IOB_SENHA in placeholders:
        print("[INFO] IOB_SENHA não configurada. Login será totalmente manual.")
        return

    wait = WebDriverWait(driver, 30)

    candidatos_usuario = [
        (By.ID, "username"),
        (By.NAME, "username"),
        (By.CSS_SELECTOR, "input#username"),
        (By.CSS_SELECTOR, "input[name='username']"),
        (By.CSS_SELECTOR, "input[type='email']"),
        (By.CSS_SELECTOR, "input[type='text']"),
    ]

    candidatos_senha = [
        (By.ID, "password"),
        (By.NAME, "password"),
        (By.CSS_SELECTOR, "input#password"),
        (By.CSS_SELECTOR, "input[name='password']"),
        (By.CSS_SELECTOR, "input[type='password']"),
    ]

    campo_usuario = None
    campo_senha = None

    # Campo usuário
    for by_u, sel_u in candidatos_usuario:
        try:
            campo_usuario = wait.until(
                EC.presence_of_element_located((by_u, sel_u))
            )
            if campo_usuario:
                break
        except TimeoutException:
            continue

    # Campo senha
    for by_s, sel_s in candidatos_senha:
        try:
            campo_senha = wait.until(
                EC.presence_of_element_located((by_s, sel_s))
            )
            if campo_senha:
                break
        except TimeoutException:
            continue

    if not campo_usuario or not campo_senha:
        print("[AVISO] Não foi possível localizar automaticamente os campos de login.")
        print("        Faça o login manualmente na tela do navegador.")
        return

    try:
        campo_usuario.clear()
        campo_usuario.send_keys(IOB_USUARIO)

        campo_senha.clear()
        campo_senha.send_keys(IOB_SENHA)

        print("[OK] Campos de usuário e senha preenchidos. Resolva o captcha (se houver) e clique em Entrar.")
    except Exception as e:
        print(f"[ERRO] Falha ao preencher login automaticamente: {e}")
        print("       Faça o login manualmente na tela do navegador.")


def abrir_firefox_e_aguardar_login():
    """
    Abre o Firefox na tela de login da IOB, tenta preencher usuário/senha
    e espera você finalizar o login (captcha / botão Entrar).
    """
    print("[INFO] Abrindo Firefox...")
    opts = FirefoxOptions()
    # Se precisar rodar em modo headless, descomente:
    # opts.add_argument("--headless")

    try:
        driver = webdriver.Firefox(options=opts)
    except WebDriverException as e:
        print("[ERRO] Não foi possível iniciar o Firefox. Verifique o geckodriver/Firefox instalados:")
        print(e)
        sys.exit(1)

    driver.maximize_window()
    driver.get(URL_LOGIN_IOB)

    print("[INFO] Firefox aberto na tela de login da IOB.")
    tentar_preencher_login_iob(driver)

    input("\nQuando estiver logado e a tela principal/painel estiver carregada, pressione ENTER aqui no console para continuar... ")

    # Pequeno tempo extra pra garantir que a SPA terminou de montar a UI
    time.sleep(3)

    return driver


def executar_download_efds():
    """
    Executa o script 'Download EFDs v3' usando o mesmo interpretador Python.
    """
    print("\n[INFO] Executando script de download das EFDs...")
    print("       Caminho:", SCRIPT_DOWNLOAD_EFDS)

    if not os.path.exists(SCRIPT_DOWNLOAD_EFDS):
        raise RuntimeError(f"[ERRO] Script de download EFDs não encontrado: {SCRIPT_DOWNLOAD_EFDS}")

    cmd = [sys.executable, SCRIPT_DOWNLOAD_EFDS]
    result = subprocess.run(cmd)

    if result.returncode != 0:
        raise RuntimeError(f"[ERRO] Script de download EFDs terminou com código != 0 (ret={result.returncode})")

    print("[OK] Script de download EFDs finalizado.")


def criar_zip_com_efds(dir_origem: str) -> str:
    """
    Cria um ZIP com os arquivos .TXT da PASTA BASE dir_origem (apenas).
    - Ignora subpastas completamente.
    - Ignora qualquer arquivo que não seja .txt.
    O zip é salvo dentro da própria pasta, com timestamp.
    """
    if not os.path.isdir(dir_origem):
        raise RuntimeError(f"[ERRO] Pasta de EFDs não encontrada: {dir_origem}")

    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    zip_path = os.path.join(dir_origem, f"EFDs_{ts}.zip")

    print("\n[INFO] Criando ZIP com as EFDs (apenas .TXT da pasta base)...")
    print("       Origem:", dir_origem)
    print("       ZIP   :", zip_path)

    arquivos_adicionados = 0

    with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as zf:
        # Apenas arquivos diretamente na pasta base
        for fname in os.listdir(dir_origem):
            fpath = os.path.join(dir_origem, fname)

            # Ignorar subpastas
            if not os.path.isfile(fpath):
                continue

            # Incluir somente .txt
            if not fname.lower().endswith(".txt"):
                continue

            zf.write(fpath, fname)  # nome simples dentro do zip
            arquivos_adicionados += 1

    if arquivos_adicionados == 0:
        print("[AVISO] Nenhum arquivo .TXT encontrado na pasta base para adicionar ao ZIP.")
    else:
        print(f"[OK] {arquivos_adicionados} arquivo(s) .TXT adicionados ao ZIP.")

    return zip_path


def clicar_menu_bolinhas(driver, wait):
    """
    Tenta clicar no ícone do menu (bolinhas) de forma mais robusta.
    """
    # 1ª tentativa: seletor principal (CSS)
    try:
        btn_menu = wait.until(EC.element_to_be_clickable(SEL_BTN_MENU_DOTS))
        btn_menu.click()
        print("[OK] Menu (bolinhas) clicado pelo seletor principal.")
        return
    except TimeoutException:
        print("[AVISO] Seletor principal do menu não encontrado. Tentando fallback...")

    # 2ª tentativa: XPATH direto no svg
    try:
        alt_sel = (By.XPATH, "//svg[contains(@class, 'iconify--material-symbols-light')]")
        btn_menu = wait.until(EC.element_to_be_clickable(alt_sel))
        btn_menu.click()
        print("[OK] Menu (bolinhas) clicado pelo seletor alternativo (XPATH).")
        return
    except TimeoutException:
        print("[AVISO] Seletor alternativo (XPATH) também não funcionou. Tentando inspeção manual.")

    # 3ª tentativa: pegar todos os SVGs com essa classe e clicar no primeiro visível
    try:
        icons = driver.find_elements(By.CSS_SELECTOR, "svg.iconify--material-symbols-light")
        print(f"[DEBUG] Encontrados {len(icons)} SVG(s) com class 'iconify--material-symbols-light'.")
        for idx, el in enumerate(icons):
            try:
                if el.is_displayed():
                    el.click()
                    print(f"[OK] Menu (bolinhas) clicado manualmente no SVG índice {idx}.")
                    return
            except Exception:
                continue
    except Exception as e:
        print(f"[DEBUG] Erro ao listar ícones de menu: {e}")

    # Se chegou aqui, não deu mesmo
    raise RuntimeError("[ERRO] Não foi possível localizar o botão do menu (ícone de bolinhas).")


def navegar_para_automacao_sped(driver):
    """
    Abre o menu (ícone de bolinhas) > Tributária > Automação SPED.
    Pressupõe que o usuário já está logado e na tela principal/painel.
    """
    print("\n[INFO] Navegando para Tributária > Automação SPED...")
    wait = WebDriverWait(driver, 30)

    # 1) Clicar no botão de menu (ícone de bolinhas)
    clicar_menu_bolinhas(driver, wait)
    time.sleep(1)

    # 2) Clicar em "Tributária"
    try:
        item_tributaria = wait.until(EC.element_to_be_clickable(SEL_MENU_ITEM_TRIBUTARIA))
        item_tributaria.click()
        time.sleep(2)
        print("[OK] Item 'Tributária' clicado.")
    except TimeoutException:
        raise RuntimeError("[ERRO] Não foi possível localizar o item de menu 'Tributária'.")

    # 3) Clicar em "Automação SPED"
    try:
        card_aut_sped = wait.until(EC.element_to_be_clickable(SEL_CARD_AUTOMACAO_SPED))
        card_aut_sped.click()
        time.sleep(5)
        print("[OK] Card 'Automação SPED' clicado.")
    except TimeoutException:
        raise RuntimeError("[ERRO] Não foi possível localizar 'Automação SPED'.")


def acessar_painel_e_importar_sped(driver: webdriver.Firefox, zip_path: str):
    """
    Depois de logado, navega até Tributária > Automação SPED
    e faz o upload do ZIP das EFDs.
    """
    wait = WebDriverWait(driver, 60)

    # 1) Ir para a tela correta: Tributária > Automação SPED
    navegar_para_automacao_sped(driver)

    # 2) Clicar em "Importar Arquivo SPED"
    print("\n[INFO] Clicando em 'Importar Arquivo SPED'...")
    try:
        btn_import = wait.until(EC.element_to_be_clickable(SEL_BTN_IMPORTAR_SPED))
        btn_import.click()
        time.sleep(3)
        print("[OK] Botão 'Importar Arquivo SPED' clicado.")
    except TimeoutException:
        raise RuntimeError("[ERRO] Não foi possível localizar o botão 'Importar Arquivo SPED'.")

    # 3) Clicar no texto "upload"
    print("[INFO] Clicando em 'upload'...")
    try:
        span_upload = wait.until(EC.element_to_be_clickable(SEL_SPAN_UPLOAD))
        span_upload.click()
        # >>> ajuste pedido: esperar entre 3 e 5 segundos (coloquei 4s) <<<
        time.sleep(4)
        print("[OK] Texto 'upload' clicado. Aguardando abertura do seletor de arquivo...")
    except TimeoutException:
        raise RuntimeError("[ERRO] Não foi possível localizar o texto 'upload'.")

    # 4) Localizar o <input type='file'> e enviar o caminho do ZIP
    print(f"[INFO] Enviando arquivo ZIP: {zip_path}")
    try:
        input_file = wait.until(
            EC.presence_of_element_located((By.CSS_SELECTOR, "input[type='file']"))
        )
        input_file.send_keys(zip_path)
        time.sleep(5)
        print("[OK] Caminho do ZIP enviado ao input de arquivo.")
    except TimeoutException:
        raise RuntimeError("[ERRO] Não foi possível localizar o campo de upload (input[type='file']).")

    # 5) Clicar em "Confirmar"
    print("[INFO] Clicando em 'Confirmar' para concluir o upload...")
    try:
        btn_conf = wait.until(EC.element_to_be_clickable(SEL_BTN_CONFIRMAR))
        btn_conf.click()
        time.sleep(5)
        print("[OK] Botão 'Confirmar' clicado. Upload do SPED concluído (veja o status na tela da IOB).")
    except TimeoutException:
        raise RuntimeError("[ERRO] Não foi possível localizar o botão 'Confirmar'.")


