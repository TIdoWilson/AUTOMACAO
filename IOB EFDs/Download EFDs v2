    print("Comando de geração enviado.")


def calcular_mes_anterior():
    hoje = datetime.today()
    mes = hoje.month
    ano = hoje.year
    if mes == 1:
        return f"12/{ano-1}"
    return f"{mes-1:02d}/{ano}"


def aguardar_sem_novos_arquivos(pasta, segundos_sem_novos=240, intervalo_check=5):
    """Considera concluído quando ficar 'segundos_sem_novos' segundos
    SEM aparecer nenhum arquivo novo na pasta.

    Janela deslizante: sempre que aparece arquivo novo, o relógio zera.
    """
    print(f"\nMonitorando pasta para novos arquivos: {pasta}")

    try:
        # mapa nome -> mtime
        estado_atual = {
            nome: os.path.getmtime(os.path.join(pasta, nome))
            for nome in os.listdir(pasta)
        }
    except FileNotFoundError:
        print("Pasta de destino não existe. Prosseguindo mesmo assim.")
        return

    ultima_mudanca = time.time()
    print(f"Esperando ficar {segundos_sem_novos} segundos sem arquivos novos...")

    while True:
        time.sleep(intervalo_check)

        try:
            novos_estado = {
                nome: os.path.getmtime(os.path.join(pasta, nome))
                for nome in os.listdir(pasta)
            }
        except FileNotFoundError:
            print("Pasta de destino sumiu durante a monitoração. Encerrando espera.")
            break

        # arquivos que ainda não existiam
        novos = [n for n in novos_estado.keys() if n not in estado_atual]

        if novos:
            print(f"Novos arquivos detectados: {novos}")
            estado_atual = novos_estado
            ultima_mudanca = time.time()

        # tempo desde a última mudança
        if time.time() - ultima_mudanca >= segundos_sem_novos:
            print(f"Não aparecem arquivos novos há {segundos_sem_novos} segundos. Considerando concluído.")
            break

    print("Monitoramento de novos arquivos finalizado.")


def remover_duplicados_mantendo_mais_recente(pasta):
    """Remove arquivos "duplicados", mantendo o mais recente por base de nome.

    A base é o nome sem sufixos do tipo:
      - ' (1)', ' (2)', etc. antes da extensão.

    Exemplo:
      - EFD_SPED.txt
      - EFD_SPED (1).txt
      - EFD_SPED (2).txt

    Mantém apenas o mais novo (por mtime) dentre esses.
    """
    print(f"\nRemovendo duplicados na pasta: {pasta}")

    try:
        arquivos = os.listdir(pasta)
    except FileNotFoundError:
        print("Pasta de destino não encontrada. Nada a remover.")
        return

    # regex para normalizar: nome_base (opcional ' (n)') + extensão
    padrao = re.compile(r"^(?P<base>.*?)( \(\d+\))?(?P<ext>\.[^.]+)?$")
    grupos = {}  # chave: base_normalizada -> lista de (caminho_completo, mtime)

    for nome in arquivos:
        caminho = os.path.join(pasta, nome)
        if not os.path.isfile(caminho):
            continue

        m = padrao.match(nome)
        if not m:
            base = nome
        else:
            base = (m.group("base") or "") + (m.group("ext") or "")

        mtime = os.path.getmtime(caminho)
        grupos.setdefault(base, []).append((caminho, mtime))

    removidos = []

    for base, lst in grupos.items():
        if len(lst) <= 1:
            continue  # não há duplicata

        # ordena por mtime (mais recente por último)
        lst.sort(key=lambda x: x[1])
        # mantém o último (mais recente)
        manter = lst[-1][0]
        descartar = [c for c, _ in lst[:-1]]

        for caminho in descartar:
            try:
                os.remove(caminho)
                removidos.append(caminho)
            except Exception as e:
                print(f"Não consegui remover '{caminho}': {e}")

        print(f"Base '{base}': mantendo '{manter}', removidos {len(descartar)} duplicados.")

    if not removidos:
        print("Nenhum duplicado encontrado.")
    else:
        print(f"Total de arquivos removidos como duplicados: {len(removidos)}")


def main():
    mes_ano = calcular_mes_anterior()
