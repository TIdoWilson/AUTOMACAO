def tentar_seq_menu(fiscal, teclas_seq, timeout_efd=8.0):
    for k in teclas_seq:
        fiscal.set_focus()
        fiscal.type_keys(k, set_foreground=True)
        time.sleep(0.7)

    end_time = time.time() + timeout_efd
    while time.time() < end_time:
        efd = achar_janela_efd(fiscal)
        if efd is not None:
            try:
                efd.set_focus()
            except Exception:
                pass
            return efd
        time.sleep(0.5)

    return None


