def localizar_campo_por_autoid(efd, autoid, tipo="Edit"):
    """
    Localiza um controle dentro da janela EFD pelo AutomationId.
    """
    print(f"  -> Procurando campo com AutomationId={autoid} ...")
    try:
        spec = efd.child_window(auto_id=autoid, control_type=tipo)
        ctrl = spec.wrapper_object()
        print(f"     ✔ Campo encontrado: {ctrl}")
        return ctrl
    except Exception:
        # debug: listar alguns descendants
        print(f"❌ Não achei controle com AutomationId={autoid}. AutomationIds de alguns descendants:")
        try:
            for d in efd.descendants():
                try:
                    t = d.window_text()
                    aid = d.element_info.automation_id
                    ct = d.element_info.control_type
                    print(f"   - type={ct:10} auto_id={aid:10} text='{t}'")
                except Exception:
                    continue
        except Exception:
            pass
        raise RuntimeError(f"Campo com AutomationId={autoid} não encontrado.")


