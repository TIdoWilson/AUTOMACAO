from pywinauto import Desktop
from datetime import datetime
import time
import os

DIR_DESTINO = r"C:\Users\Usuario\Desktop\teste"

BOTAO_GERAR_TITLE = "Gerar"

CLASSE_FISCAL = "TfrmPrincipal"
CLASSE_EFD    = "TfrmGeracaoMultiEmpresaSped"

# AUTO_ID dos campos
AUTOID_PROCESSAMENTO = "2099668"
AUTOID_MES_ANO       = "10094896"
AUTOID_GRUPO         = "723364"
AUTOID_DIRETORIO     = "5703752"


def localizar_janela_fiscal(timeout=30):
    print("Procurando a janela do módulo Fiscal (classe TfrmPrincipal)...")

    end_time = time.time() + timeout
    ja_listou = False

    while time.time() < end_time:
        try:
            janelas = Desktop(backend="uia").windows()
        except Exception:
            janelas = []

        fiscal = None

        for w in janelas:
            try:
                titulo = w.window_text()
                classe = w.element_info.class_name
            except Exception:
                continue

            if not ja_listou:
                print(f"  - janela encontrada: '{titulo}' (classe={classe})")

            if classe == CLASSE_FISCAL and "Fiscal" in (titulo or ""):
                fiscal = w
                break

        ja_listou = True

        if fiscal is not None:
            print(f"✔ Janela do módulo Fiscal encontrada: '{fiscal.window_text()}'")
            return fiscal

        time.sleep(0.5)

    raise RuntimeError("Não consegui localizar a janela do módulo Fiscal dentro do tempo limite.")


def achar_janela_efd(fiscal=None):
    """
    Procura a tela de geração das EFDs pela classe TfrmGeracaoMultiEmpresaSped.

    1) Descendants da janela Fiscal.
    2) Fallback: janelas top-level.
    """

    if fiscal is not None:
        try:
            for ctrl in fiscal.descendants():
                try:
                    cls = ctrl.element_info.class_name
                except Exception:
                    continue
                if cls == CLASSE_EFD:
                    return ctrl
        except Exception:
            pass

    for w in Desktop(backend="uia").windows():
        try:
            if w.element_info.class_name == CLASSE_EFD:
                return w
        except Exception:
            continue

    return None


def tentar_seq_menu(fiscal, teclas_seq, timeout_efd=8.0):
    for k in teclas_seq:
        fiscal.set_focus()
        fiscal.type_keys(k, set_foreground=True)
        time.sleep(0.7)

    end_time = time.time() + timeout_efd
    while time.time() < end_time:
        efd = achar_janela_efd(fiscal)
        if efd is not None:
            try:
                efd.set_focus()
            except Exception:
                pass
            return efd
        time.sleep(0.3)
    return None


def abrir_tela_efd():
    fiscal = localizar_janela_fiscal()
    fiscal.set_focus()

    # se já estiver aberta, usa
    efd = achar_janela_efd(fiscal)
    if efd is not None:
        print("Tela 'Geração das EFDs' já estava aberta.")
        try:
            efd.set_focus()
        except Exception:
            pass
        return efd

    print("Abrindo caminho para 'Geração das EFDs'...")

    seq1 = ['%m', 'g', 'p', 'p', 'g']  # Alt+M -> Geração de Arquivos -> SPED -> Processamento Agrupado -> Geração das EFDs
    seq2 = ['%g', 'p', 'p', 'g']       # Alt+G -> SPED -> Processamento Agrupado -> Geração das EFDs

    for seq in (seq1, seq2):
        efd = tentar_seq_menu(fiscal, seq)
        if efd is not None:
            print("✔ Janela 'Geração das EFDs' localizada (classe TfrmGeracaoMultiEmpresaSped).")
            return efd

    print("Não encontrei a janela 'Geração das EFDs'. Janelas da classe TfrmGeracaoMultiEmpresaSped (Desktop e Fiscal):")

    encontrou = False

    try:
        for ctrl in fiscal.descendants():
            try:
                cls = ctrl.element_info.class_name
                titulo = ctrl.window_text()
            except Exception:
                continue
            if cls == CLASSE_EFD:
                print(f"  - DESC '{titulo}' (classe={cls})")
                encontrou = True
    except Exception:
        pass

    for w in Desktop(backend="uia").windows():
        try:
            cls = w.element_info.class_name
            titulo = w.window_text()
        except Exception:
            continue
        if cls == CLASSE_EFD:
            print(f"  - TOP '{titulo}' (classe={cls})")
            encontrou = True

    if not encontrou:
        print("  (nenhuma)")

    raise RuntimeError("Não consegui encontrar a janela 'Geração das EFDs'.")


def localizar_campo_por_autoid(efd, auto_id):
    for ctrl in efd.descendants(control_type="Edit"):
        try:
            if ctrl.element_info.automation_id == auto_id:
                return ctrl
        except Exception:
            continue
    return None


def pegar_edits_ordenados(efd):
    edits = []
    for ctrl in efd.descendants(control_type="Edit"):
        try:
            rect = ctrl.element_info.rectangle
            edits.append((rect.top, rect.left, ctrl))
        except Exception:
            continue

    edits.sort(key=lambda x: (x[0], x[1]))
    ordered = [c for _, _, c in edits]

    print("\n=== EDITS ENCONTRADOS (ORDEM TOPO-ESQUERDA) ===")
    for i, c in enumerate(ordered):
        try:
            info = c.element_info
            rect = info.rectangle
            txt = ""
            try:
                txt = c.window_text()
            except Exception:
                pass
            print(f"  [{i}] top={rect.top:4} left={rect.left:4} texto={repr(txt)} auto_id={info.automation_id}")
        except Exception:
            continue

    return ordered


def preencher_campos_efd(efd, mes_ano):
    campo_processamento = localizar_campo_por_autoid(efd, AUTOID_PROCESSAMENTO)
    campo_mes_ano       = localizar_campo_por_autoid(efd, AUTOID_MES_ANO)
    campo_grupo         = localizar_campo_por_autoid(efd, AUTOID_GRUPO)
    campo_diretorio     = localizar_campo_por_autoid(efd, AUTOID_DIRETORIO)

    if None in (campo_processamento, campo_mes_ano, campo_grupo, campo_diretorio):
        print("Nem todos os campos foram encontrados por AutomationId. Usando ordem dos edits como fallback.")
        edits = pegar_edits_ordenados(efd)
        if len(edits) < 7:
            raise RuntimeError(f"Esperava pelo menos 7 edits, encontrei {len(edits)}")

        if campo_processamento is None:
            campo_processamento = edits[0]
        if campo_mes_ano is None:
            campo_mes_ano = edits[1]
        if campo_grupo is None:
            campo_grupo = edits[5]
        if campo_diretorio is None:
            campo_diretorio = edits[6]

    print("\nPreenchendo Processamento = 2...")
    campo_processamento.set_focus()
    campo_processamento.type_keys("^a{BACKSPACE}2")

    print(f"Preenchendo Mês/Ano = {mes_ano} ...")
    campo_mes_ano.set_focus()
    campo_mes_ano.type_keys("^a{BACKSPACE}" + mes_ano, with_spaces=True)

    print("Preenchendo Grupo = 32...")
    campo_grupo.set_focus()
    campo_grupo.type_keys("^a{BACKSPACE}32")

    print(f"Preenchendo Diretório Destino = {DIR_DESTINO} ...")
    campo_diretorio.set_focus()
    campo_diretorio.type_keys("^a{BACKSPACE}" + DIR_DESTINO, with_spaces=True)


def clicar_gerar(efd):
    print("\nLocalizando botão 'Gerar'...")

    botao = None

    # procura qualquer botão com texto "Gerar"
    for ctrl in efd.descendants(control_type="Button"):
        try:
            texto = (ctrl.window_text() or "").strip().lower()
        except Exception:
            continue

        if texto == BOTAO_GERAR_TITLE.lower():
            botao = ctrl
            break

    if botao is None:
        print("Botão 'Gerar' não encontrado. Botões encontrados para debug:")
        try:
            for ctrl in efd.descendants(control_type="Button"):
                try:
                    txt = ctrl.window_text()
                    cls = ctrl.element_info.class_name
                    print(f"  - '{txt}' (classe={cls})")
                except Exception:
                    continue
        except Exception:
            pass
        raise RuntimeError("Botão 'Gerar' não foi localizado na tela de EFD.")

    print("Clicando em 'Gerar'...")
    botao.click_input()
    print("Comando de geração enviado.")

def calcular_mes_anterior():
    hoje = datetime.today()
    mes = hoje.month
    ano = hoje.year
    if mes == 1:
        return f"12/{ano-1}"
    return f"{mes-1:02d}/{ano}"


def main():
    mes_ano = calcular_mes_anterior()
    print(f"Mês/Ano detectado automaticamente (mês anterior): {mes_ano}")

    efd = abrir_tela_efd()

    preencher_campos_efd(efd, mes_ano)

    clicar_gerar(efd)

    print("\nProcesso de geração iniciado automaticamente.")

def esperar_downloads_concluir(pasta, timeout_segundos=240):
    """
    Monitora a pasta de downloads e considera concluído quando:
      - não existirem arquivos temporários (.part, .crdownload, .tmp), e
      - houver mudança na lista de arquivos em relação ao início
    OU
      - estourar o timeout de 4 minutos.
    """
    print(f"\nMonitorando downloads na pasta: {pasta}")
    inicio = time.time()

    try:
        estado_inicial = set(os.listdir(pasta))
    except FileNotFoundError:
        print("Pasta de downloads não existe. Prosseguindo mesmo assim.")
        return

    while True:
        agora = time.time()
        if agora - inicio > timeout_segundos:
            print("Tempo limite de 4 minutos atingido. Prosseguindo mesmo assim.")
            break

        time.sleep(5)

        try:
            arquivos = os.listdir(pasta)
        except FileNotFoundError:
            print("Pasta de downloads não encontrada durante a monitoração.")
            break

        # Se ainda existir arquivo parcial, continua esperando
        if any(
            nome.lower().endswith((".part", ".crdownload", ".tmp"))
            for nome in arquivos
        ):
            continue

        # Se houve alteração em relação ao estado inicial, assume que gerou algo
        if set(arquivos) != estado_inicial:
            print("Alteração detectada na pasta de downloads. Assumindo que as EFDs foram geradas.")
            break

    print("Download das EFDs considerado concluído.")

if __name__ == "__main__":
    main()
