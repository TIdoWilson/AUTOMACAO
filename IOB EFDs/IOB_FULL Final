# =============== FUNÇÃO: MÊS/ANO + PASTA EFDs ===============

def calcular_mes_ano_e_pasta():
    """
    Retorna (mes_ano_str, pasta_efds), onde:
      mes_ano_str  = 'MM/AAAA' do mês anterior ao atual
      pasta_efds   = W:\\SPEDs\\EFD CONTRIBUIÇÕES\\AAAA\\MM.AAAA\\AUTOMATIZADO
    Cria a pasta se não existir.
    """
    hoje = datetime.today()
    mes = hoje.month
    ano = hoje.year

    if mes == 1:
        mes_ref = 12
        ano_ref = ano - 1
    else:
        mes_ref = mes - 1
        ano_ref = ano

    mes_ano_str = f"{mes_ref:02d}/{ano_ref}"
    pasta_ano = str(ano_ref)
    pasta_mes_ano = f"{mes_ref:02d}.{ano_ref}"

    pasta_efds = os.path.join(BASE_SPEDS, pasta_ano, pasta_mes_ano, "AUTOMATIZADO")
    os.makedirs(pasta_efds, exist_ok=True)

    return mes_ano_str, pasta_efds


# =============== SELETORES (WEB) ===============

