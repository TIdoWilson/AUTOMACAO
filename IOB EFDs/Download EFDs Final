from pywinauto import Desktop, Application
from datetime import datetime
import time
import os

# =========================
# CONFIGURAÇÕES
# =========================

# Raiz dos SPEDs (ajuste aqui se mudar a estrutura)
BASE_SPEDS = r"W:\SPEDs\EFD CONTRIBUIÇÕES"

# Valor usado no campo "Gerar por" (pode mudar aqui quando quiser)
GERAR_POR_VALOR = "1"

# Mapeamento por índice (ordem vertical dos campos Edit)
# 0 = Processamento
# 1 = Mês/Ano
# 2 = Período (de)
# 3 = Período (até)
# 4 = Gerar por
# 5 = Grupo
# 6 = Diretório Destino
# 7 = E-mail
IDX_PROCESSAMENTO = 0
IDX_MES_ANO      = 1
IDX_GERAR_POR    = 4
IDX_GRUPO        = 5
IDX_DIRETORIO    = 6

BOTAO_GERAR_TITLE = "Gerar"

CLASSE_FISCAL = "TfrmPrincipal"
CLASSE_EFD    = "TfrmGeracaoMultiEmpresaSped"

# =========================
# LOG SIMPLES
# =========================

try:
    SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
except NameError:
    SCRIPT_DIR = os.getcwd()

LOG_FILE = os.path.join(SCRIPT_DIR, "IOB_EFD_AUTOMACAO.log")

def log(msg: str):
    """Escreve mensagem no console e em um arquivo de log com timestamp."""
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    linha = f"[{ts}] {msg}"
    print(linha)
    try:
        with open(LOG_FILE, "a", encoding="utf-8") as f:
            f.write(linha + "\n")
    except Exception as e:
        print(f"[LOG_ERROR] Falha ao escrever no log: {e}")


# =========================
# UTILITÁRIO: MÊS/ANO + PASTA
# =========================

def calcular_mes_ano_e_pasta():
    """
    Retorna (mes_ano_str, pasta_destino), onde:
      mes_ano_str  = 'MM/AAAA' do mês anterior ao atual
      pasta_destino = W:\\SPEDs\\EFD CONTRIBUIÇÕES\\AAAA\\MM.AAAA\\AUTOMATIZADO
    Cria a pasta se não existir.
    """
    hoje = datetime.today()
    mes = hoje.month
    ano = hoje.year

    if mes == 1:
        mes_ref = 12
        ano_ref = ano - 1
    else:
        mes_ref = mes - 1
        ano_ref = ano

    mes_ano_str = f"{mes_ref:02d}/{ano_ref}"
    pasta_ano = str(ano_ref)
    pasta_mes_ano = f"{mes_ref:02d}.{ano_ref}"

    pasta_destino = os.path.join(BASE_SPEDS, pasta_ano, pasta_mes_ano, "AUTOMATIZADO")
    os.makedirs(pasta_destino, exist_ok=True)

    log(f"Mês/Ano referência: {mes_ano_str}")
    log(f"Pasta destino calculada: {pasta_destino}")

    return mes_ano_str, pasta_destino


# =========================
# JANELA FISCAL / EFD
# =========================

def localizar_janela_fiscal(timeout=30):
    log("Procurando a janela do módulo Fiscal...")

    end_time = time.time() + timeout
    ja_listou = False

    while time.time() < end_time:
        fiscal = None
        for w in Desktop(backend="uia").windows():
            try:
                titulo = w.window_text()
                classe = w.element_info.class_name
            except Exception:
                continue

            if classe == CLASSE_FISCAL and "Fiscal" in (titulo or ""):
                fiscal = w
                break

        if fiscal is not None:
            log(f"✔ Janela do módulo Fiscal encontrada: '{fiscal.window_text()}'")
            return fiscal

        if not ja_listou:
            log("Ainda não achei o módulo Fiscal, listando algumas janelas para debug...")
            for w in Desktop(backend="uia").windows():
                try:
                    log(f"  - janela encontrada: '{w.window_text()}' (classe={w.element_info.class_name})")
                except Exception:
                    continue
            ja_listou = True

        time.sleep(1)

    raise RuntimeError("Não consegui localizar a janela do módulo Fiscal (classe TfrmPrincipal).")


def eh_janela_efd(win):
    try:
        classe = win.element_info.class_name
    except Exception:
        classe = None
    try:
        titulo = win.window_text()
    except Exception:
        titulo = ""
    try:
        ct = win.element_info.control_type
    except Exception:
        ct = None

    if ct not in ("Window", "Pane"):
        return False

    if classe == CLASSE_EFD:
        return True

    if titulo and "Geração das EFDs" in titulo:
        return True

    return False


def achar_janela_efd(fiscal=None):
    if fiscal is not None:
        try:
            for d in fiscal.descendants():
                if eh_janela_efd(d):
                    return d
        except Exception:
            pass

    try:
        for w in Desktop(backend="uia").windows():
            if eh_janela_efd(w):
                return w
    except Exception:
        pass

    return None


def abrir_tela_efd():
    fiscal_uia = localizar_janela_fiscal()
    handle = fiscal_uia.handle

    log("Conectando no módulo Fiscal via backend win32 para acionar o menu...")
    app_win32 = Application(backend="win32").connect(handle=handle)
    fiscal_win32 = app_win32.window(handle=handle)

    caminhos_menu = [
        "Módulos->Geração de Arquivos->SPED->Processamento Agrupado->Geração das EFDs",
        "Módulos->Geracao de Arquivos->SPED->Processamento Agrupado->Geração das EFDs",
        "Modulos->Geração de Arquivos->SPED->Processamento Agrupado->Geração das EFDs",
    ]

    executado = False
    ultimo_erro = None

    for caminho in caminhos_menu:
        try:
            log(f"Tentando abrir menu: {caminho}")
            fiscal_win32.set_focus()
            fiscal_win32.menu_select(caminho)
            executado = True
            log("✔ Comando de menu enviado com sucesso.")
            break
        except Exception as e:
            log(f"Falha ao usar menu_select('{caminho}'): {e}")
            ultimo_erro = e

    if not executado:
        raise RuntimeError(
            f"Não consegui acionar o menu para abrir 'Geração das EFDs'. "
            f"Último erro: {ultimo_erro}"
        )

    log("Aguardando a janela 'Geração das EFDs' aparecer...")
    end_time = time.time() + 30
    efd = None

    while time.time() < end_time:
        efd = achar_janela_efd(fiscal_uia)
        if efd is not None:
            break
        time.sleep(1)

    if efd is None:
        raise RuntimeError("Não consegui localizar a janela 'Geração das EFDs' após usar o menu.")

    if hasattr(efd, "wait"):
        efd.wait("visible", timeout=10)

    log("✔ Janela 'Geração das EFDs' localizada!")
    return efd


# =========================
# MAPEAR E PREENCHER CAMPOS
# =========================

def obter_edits_ordenados(efd):
    edits = []
    for d in efd.descendants():
        try:
            if d.element_info.control_type == "Edit":
                edits.append(d)
        except Exception:
            continue

    if not edits:
        raise RuntimeError("Não encontrei nenhum campo Edit na tela de EFD.")

    edits_ordenados = sorted(
        edits,
        key=lambda d: (getattr(d.element_info.rectangle, "top", 0),
                       getattr(d.element_info.rectangle, "left", 0))
    )

    log("Encontrados campos Edit (em ordem vertical):")
    for i, ed in enumerate(edits_ordenados):
        try:
            aid = ed.element_info.automation_id
            txt = ed.window_text()
            log(f"   [{i}] Edit auto_id={aid} text='{txt}'")
        except Exception:
            log(f"   [{i}] Edit (sem info legível)")

    return edits_ordenados


def pegar_edit_por_indice(edits, idx, nome):
    if idx < len(edits):
        ed = edits[idx]
        try:
            aid = ed.element_info.automation_id
            log(f"[OK] Campo '{nome}' = Edit índice {idx} (auto_id={aid})")
        except Exception:
            log(f"[OK] Campo '{nome}' = Edit índice {idx}")
        return ed
    else:
        log(f"[AVISO] Índice {idx} para '{nome}' está fora do número de campos ({len(edits)}).")
        return None


def preencher_campos_efd(efd, mes_ano, dir_destino):
    edits = obter_edits_ordenados(efd)

    campo_processamento = pegar_edit_por_indice(edits, IDX_PROCESSAMENTO, "Processamento")
    campo_mes_ano      = pegar_edit_por_indice(edits, IDX_MES_ANO,      "Mês/Ano")
    campo_gerar_por    = pegar_edit_por_indice(edits, IDX_GERAR_POR,    "Gerar por")
    campo_grupo        = pegar_edit_por_indice(edits, IDX_GRUPO,        "Grupo")
    campo_diretorio    = pegar_edit_por_indice(edits, IDX_DIRETORIO,    "Diretório Destino")

    log("Preenchendo campos...")

    # PRIMEIRA OPÇÃO (PROCESSAMENTO) = 2
    if campo_processamento is not None:
        log("  - Preenchendo campo 'Processamento' com '2'...")
        campo_processamento.set_focus()
        time.sleep(0.2)
        campo_processamento.type_keys("^a{BACKSPACE}")
        campo_processamento.type_keys("2")

    if campo_mes_ano is not None:
        log(f"  - Preenchendo campo 'Mês/Ano' com '{mes_ano}'...")
        campo_mes_ano.set_focus()
        time.sleep(0.2)
        campo_mes_ano.type_keys("^a{BACKSPACE}")
        campo_mes_ano.type_keys(mes_ano, with_spaces=True)

    if campo_gerar_por is not None:
        log(f"  - Preenchendo campo 'Gerar por' com '{GERAR_POR_VALOR}'...")
        campo_gerar_por.set_focus()
        time.sleep(0.2)
        campo_gerar_por.type_keys("^a{BACKSPACE}")
        campo_gerar_por.type_keys(GERAR_POR_VALOR)

    if campo_grupo is not None:
        log("  - Preenchendo campo 'Grupo' com '32'...")
        campo_grupo.set_focus()
        time.sleep(0.2)
        campo_grupo.type_keys("^a{BACKSPACE}")
        campo_grupo.type_keys("32")

    if campo_diretorio is not None:
        log(f"  - Tentando preencher campo 'Diretório Destino' com '{dir_destino}'...")
        try:
            wrapper = campo_diretorio.wrapper_object()
            wrapper.set_edit_text(dir_destino)
        except Exception as e:
            log(f"  - Erro ao usar wrapper.set_edit_text: {e}. Caindo para type_keys.")
            campo_diretorio.set_focus()
            time.sleep(0.2)
            campo_diretorio.type_keys("^a{BACKSPACE}")
            campo_diretorio.type_keys(dir_destino, with_spaces=True)

        time.sleep(0.5)

        try:
            txt_final = (campo_diretorio.window_text() or "").strip()
        except Exception as e:
            log(f"  - Erro ao ler texto do campo diretório depois de escrever: {e}")
            txt_final = ""

        log(f"  - Valor do campo Diretório agora: '{txt_final}'")

        if dir_destino not in txt_final:
            log("❌ O campo de diretório NÃO ficou com o valor esperado!")
        else:
            log("✔ Diretório ajustado com sucesso.")


# =========================
# BOTÃO GERAR E ESPERA
# =========================

def clicar_gerar(efd):
    log("Procurando o botão 'Gerar'...")

    botao = None
    for d in efd.descendants():
        try:
            if d.element_info.control_type == "Button" and d.window_text() == BOTAO_GERAR_TITLE:
                botao = d
                break
        except Exception:
            continue

    if botao is None:
        log("❌ Não localizei o botão 'Gerar' pelo título.")
        raise RuntimeError("Botão 'Gerar' não encontrado.")

    log("Clicando no botão 'Gerar'...")
    botao.click_input()
    return botao


def esperar_conclusao_geracao(botao_gerar, timeout_total=8*60*60):
    """
    Nova lógica:
      - Espera 1 hora sem checar nada (sistema pode travar à vontade).
      - Depois de 1h, começa a checar se o botão 'Gerar' está habilitado.
      - Se ainda não estiver, espera 15 minutos e checa de novo.
      - Repete até o botão estar habilitado ou até estourar timeout_total.
    """
    log("Monitorando o botão 'Gerar' para detectar conclusão da geração...")
    t0 = time.time()

    log("Aguardando 1 hora antes da primeira verificação do botão 'Gerar'...")
    time.sleep(60 * 60)  # 1 hora

    intervalo_check = 15 * 60  # 15 minutos

    while True:
        decorrido = time.time() - t0
        if decorrido > timeout_total:
            log("⚠ Tempo máximo de espera atingido ao monitorar o botão 'Gerar'. Prosseguindo mesmo assim.")
            return

        try:
            habilitado = botao_gerar.is_enabled()
        except Exception as e:
            log(f"Erro ao checar estado do botão 'Gerar': {e}")
            habilitado = False

        if habilitado:
            log("✔ Botão 'Gerar' está habilitado novamente. Geração presumivelmente concluída.")
            return

        log("Botão 'Gerar' ainda não habilitado. Aguardando mais 15 minutos para nova verificação...")
        time.sleep(intervalo_check)


# =========================
# MONITORAR ARQUIVOS
# =========================

def listar_arquivos_txt(pasta):
    try:
        return [f for f in os.listdir(pasta) if f.lower().endswith(".txt")]
    except Exception as e:
        log(f"Erro ao listar arquivos em '{pasta}': {e}")
        return []


def aguardar_sem_novos_arquivos(pasta, segundos_sem_novos=240, intervalo_check=5):
    log(f"Monitorando a pasta '{pasta}' para novos arquivos TXT...")

    conhecidos = set(listar_arquivos_txt(pasta))
    log(f"Arquivos existentes inicialmente ({len(conhecidos)}): {sorted(conhecidos)}")

    t_ultimo_novo = time.time()

    while True:
        atuais = set(listar_arquivos_txt(pasta))
        novos = atuais - conhecidos

        if novos:
            log(f"Novos arquivos detectados: {sorted(novos)}")
            conhecidos |= novos
            t_ultimo_novo = time.time()

        if time.time() - t_ultimo_novo >= segundos_sem_novos:
            log(f"✔ Nenhum arquivo novo por {segundos_sem_novos} segundos. Considerando a geração concluída.")
            break

        time.sleep(intervalo_check)


# =========================
# MAIN
# =========================

def main():
    log("===== INÍCIO DA EXECUÇÃO IOB_EFD_AUTOMACAO =====")
    mes_ano, pasta_destino = calcular_mes_ano_e_pasta()

    efd = abrir_tela_efd()
    preencher_campos_efd(efd, mes_ano, pasta_destino)

    log(f"Pasta de destino final usada: {pasta_destino}")

    botao_gerar = clicar_gerar(efd)

    log("Processo de geração iniciado automaticamente.")
    esperar_conclusao_geracao(botao_gerar)

    aguardar_sem_novos_arquivos(pasta_destino, segundos_sem_novos=240, intervalo_check=5)

    log("SINAL_EFDS_CONCLUIDO")
    log("===== FIM DA EXECUÇÃO IOB_EFD_AUTOMACAO =====")


if __name__ == "__main__":
    main()
