# ================== HELPERS GERAIS ==================

def normalizar_texto(txt: str) -> str:
    if not txt:
        return ""
    txt = unicodedata.normalize("NFD", txt)
    txt = "".join(c for c in txt if unicodedata.category(c) != "Mn")
    return txt.lower().strip()


def codigo_para_nome_arquivo(codigo: str) -> str:
    """
    Mesma lógica usada no download:
    re.sub(r"[^\w\-]", "_", codigo)
    """
    return re.sub(r"[^\w\-]", "_", str(codigo))


def registrar_cnpj_completo(cnpj: str, status_final: str, tentativas: int):
    linha = {
        "cnpj": str(cnpj),
        "status_final": str(status_final),
        "tentativas_realizadas": int(tentativas),
    }

    if os.path.exists(EXCEL_CNPJS_COMPLETOS):
        df = pd.read_excel(EXCEL_CNPJS_COMPLETOS, dtype=str)
    else:
        df = pd.DataFrame(columns=["cnpj", "status_final", "tentativas_realizadas"])

    df = pd.concat([df, pd.DataFrame([linha])], ignore_index=True)
    df.drop_duplicates(subset=["cnpj"], keep="last", inplace=True)
    df.to_excel(EXCEL_CNPJS_COMPLETOS, index=False)


