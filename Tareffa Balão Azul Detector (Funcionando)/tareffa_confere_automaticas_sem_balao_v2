def localizar_primeiro_campo(page, seletores, timeout_por_seletor=8000):
    """
    Tenta vários seletores até achar um campo.
    Evita estourar Timeout esperando um único seletor.
    """
    for sel in seletores:
        try:
            campo = page.wait_for_selector(sel, timeout=timeout_por_seletor)
            if campo:
                escrever_log(f"Campo encontrado: {sel}")
                return campo
        except PlaywrightTimeoutError:
            continue
    return None


def fazer_login(page):
    escrever_log("Iniciando login no Tareffa...")

    # Vai direto para /tasks; se não estiver logado, ele redireciona pro OAuth
    try:
        page.goto(f"{TAREFFA_URL_BASE}/tasks", wait_until="load", timeout=60000)
    except PlaywrightTimeoutError:
        # fallback antigo
        page.goto(f"{TAREFFA_URL_BASE}/login", wait_until="load")

    page.wait_for_load_state("networkidle")

    seletores_email = [
        'input[name="email"]',
        'input[type="email"]',
        'input[name="username"]',
        'input[placeholder*="email" i]',
        'input[placeholder*="e-mail" i]',
        'input[placeholder*="usuário" i]',
        'input[placeholder*="usuario" i]',
    ]

    seletores_senha = [
        'input[name="password"]',
        'input[type="password"]',
        'input[placeholder*="senha" i]',
        'input[placeholder*="password" i]',
    ]

    campo_email = localizar_primeiro_campo(page, seletores_email)
    if not campo_email:
        escrever_log("Não consegui localizar campo de e-mail/usuário na tela de login.")
        return

    campo_email.fill(TAREFFA_EMAIL)

    campo_senha = localizar_primeiro_campo(page, seletores_senha)
    if not campo_senha:
        escrever_log("Não consegui localizar campo de senha na tela de login.")
        return

    campo_senha.fill(TAREFFA_SENHA)

    botoes_login = [
        "button[type='submit']",
        "button:has-text('Entrar')",
        "button:has-text('Acessar')",
        "button:has-text('Login')",
        "button:has-text('Continuar')",
        "button:has-text('Continuar com e-mail')",
    ]

    clicou = False
    for sel in botoes_login:
        btn = page.locator(sel)
        if btn.count() > 0:
            escrever_log(f"Clicando no botão de login: {sel}")
            btn.first.click()
            clicou = True
            break

    if not clicou:
        escrever_log("Não encontrei botão de login para clicar.")
        return

    try:
        page.wait_for_url(re.compile(r".*/tasks"), timeout=60000)
        escrever_log("Login realizado com sucesso.")
    except PlaywrightTimeoutError:
        escrever_log("Não foi possível confirmar o login (timeout). Verifique visualmente se entrou.")

    page.wait_for_timeout(3000)
    confirmar_modo_minimalista(page)


