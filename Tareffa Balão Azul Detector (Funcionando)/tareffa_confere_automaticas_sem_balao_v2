def remover_acentos(texto):
    if not isinstance(texto, str):
        return texto
    nfkd = unicodedata.normalize("NFKD", texto)
    return "".join(c for c in nfkd if not unicodedata.combining(c))


def normalizar_texto(texto):
    if not isinstance(texto, str):
        return ""
    texto = remover_acentos(texto)
    texto = texto.upper()
    texto = re.sub(r"\s+", " ", texto)
    return texto.strip()


def carregar_base_servicos(caminho_csv):
    """
    Carrega o CSV de serviços e cria um dicionário:
      base_servicos[(depto_normalizado, servico_normalizado)] = {
         'Departamento': ...,
         'Servico': ...,
      }

    Faz detecção automática das colunas (Departamento / Serviço),
    mesmo que venham com acento ou nomes maiores.
    """
    # tenta UTF-8, se der erro cai pra Latin-1 (Windows)
    try:
        df = pd.read_csv(caminho_csv, sep=";", dtype=str, encoding="utf-8").fillna("")
    except UnicodeDecodeError:
        df = pd.read_csv(caminho_csv, sep=";", dtype=str, encoding="latin1").fillna("")

    if df.empty:
        escrever_log("CSV de serviços está vazio.")
        return {}

    # normaliza nomes de coluna para localizar Departamento / Serviço
    colunas_norm = {}
    for col in df.columns:
        # remove acentos, joga pra maiúsculo, tira espaços e _
        norm = remover_acentos(str(col)).upper()
        norm = norm.replace(" ", "").replace("_", "")
        colunas_norm[col] = norm

    def achar_col(alvo_substring):
        alvo_substring = alvo_substring.upper()
        for col, norm in colunas_norm.items():
            if alvo_substring in norm:
                return col
        return None

    col_depto = achar_col("DEPARTAMENTO")
    col_serv = achar_col("SERVICO")  # pega "SERVIÇO" também, pois removi acento

    if not col_serv:
        escrever_log(
            f"Não achei coluna de Serviço no CSV. Colunas encontradas: {list(df.columns)}"
        )
        return {}

    if not col_depto:
        escrever_log(
            "Não achei coluna de Departamento no CSV. "
            "Vou carregar só por Serviço (Departamento vazio)."
        )

    base = {}
    for _, row in df.iterrows():
        serv_original = row.get(col_serv, "")
        serv_norm = normalizar_texto(serv_original)

        if not serv_norm:
            continue

        if col_depto:
            depto_original = row.get(col_depto, "")
            depto_norm = normalizar_texto(depto_original)
        else:
            depto_original = ""
            depto_norm = ""

        # chave usa depto_norm + serv_norm
        base[(depto_norm, serv_norm)] = {
            "Departamento": depto_original,
            "Servico": serv_original,
        }

    escrever_log(f"Base de serviços carregada a partir do CSV: {len(base)} combinações depto/serviço.")
    return base


def ler_arquivo_controle_dias(caminho):
    """
    Lê (ou cria) arquivo de controle de dias.
    Colunas: Data, Status, Ultima_execucao, Observacao
    """
    if os.path.exists(caminho):
        df = pd.read_excel(caminho, dtype=str)
        colunas_minimas = ["Data", "Status", "Ultima_execucao", "Observacao"]
        for col in colunas_minimas:
            if col not in df.columns:
                df[col] = ""
    else:
        df = pd.DataFrame(columns=["Data", "Status", "Ultima_execucao", "Observacao"])
    return df


