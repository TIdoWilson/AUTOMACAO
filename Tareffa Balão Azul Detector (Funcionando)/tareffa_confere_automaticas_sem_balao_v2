def carregar_todos_registros_lista(page):
    """
    Faz scroll na lista até carregar todos os registros visíveis naquele filtro.
    Retorna:
      - lista_rows: lista de dicts representando cada linha
      - linhas_incons_depto: lista de detalhes de inconsistência por departamento/serviço
      - fim_confirmado: bool se chegou ao final da lista de forma confiável
    """
    escrever_log("Carregando todos os registros da lista...")
    linhas = []
    linhas_incons_depto = []
    fim_confirmado = False

    SELETOR_CONTAINER_LISTA = "#card-content"

    try:
        container = page.wait_for_selector(SELETOR_CONTAINER_LISTA, timeout=10000)
    except PlaywrightTimeoutError:
        escrever_log("Não encontrei o container da lista de serviços (timeout).")
        return [], [], False

    altura_anterior = -1
    tentativas_iguais = 0
    limite_tentativas_iguais = 5

    while True:
        altura_atual = page.evaluate(
            """(sel) => {
                const el = document.querySelector(sel);
                return el ? el.scrollHeight : 0;
            }""",
            SELETOR_CONTAINER_LISTA,
        )

        escrever_log(
            f"Scroll: altura_atual={altura_atual}, altura_anterior={altura_anterior}, "
            f"tentativas_iguais={tentativas_iguais}"
        )

        if altura_atual <= 0:
            escrever_log("Altura do container zero ou negativa, algo estranho na página.")
            break

        if altura_atual == altura_anterior:
            tentativas_iguais += 1
            if tentativas_iguais >= limite_tentativas_iguais:
                fim_confirmado = True
                escrever_log("Altura da lista não aumenta mais, fim confirmado.")
                break
        else:
            tentativas_iguais = 0
            altura_anterior = altura_atual

        page.evaluate(
            """(sel) => {
                const el = document.querySelector(sel);
                if (!el) return;
                el.scrollTop = el.scrollHeight;
            }""",
            SELETOR_CONTAINER_LISTA,
        )
        page.wait_for_timeout(1500)

    escrever_log("Coletando linhas da lista após scroll máximo.")
    try:
        itens = page.locator(f"{SELETOR_CONTAINER_LISTA} .table-body .table-row")
        qtd_itens = itens.count()
        escrever_log(f"Quantidade de linhas detectadas na lista: {qtd_itens}")
        for i in range(qtd_itens):
            row = itens.nth(i)
            texto_row = row.inner_text()
            colunas = row.locator(".table-cell")
            qtd_cols = colunas.count()
            celulas_texto = []
            for c in range(qtd_cols):
                celulas_texto.append(colunas.nth(c).inner_text().strip())
            info_aux = extrair_campos_auxiliares(texto_row, celulas_texto)

            linha = {
                "linha_index": i,
                "texto_row": texto_row,
                "celulas": celulas_texto,
                "aux": info_aux,
            }
            linhas.append(linha)
    except Exception as e:
        escrever_log(f"Erro ao coletar linhas da lista: {e}")

    return linhas, linhas_incons_depto, fim_confirmado


def detectar_se_ha_balao_azul(row_element):
    """
    Dado o elemento de linha (row), detecta se há balão azul (ícone ou classe indicativa).
    """
    try:
        icone_balao = row_element.locator(f"i.{ICONE_BOTAO_BALOES}")
        if icone_balao.count() > 0:
            classes = icone_balao.first.get_attribute("class") or ""
            if "text-primary" in classes or "text-blue" in classes:
                return True
        return False
    except Exception:
        return False


def verificar_baloes_nas_linhas(page, linhas, base_servicos, data_do_dia_str):
    """
    Para cada linha, verifica se há balão azul. Em caso negativo, registra inconsistencia.
    """
    inconsistencias = []

    SELETOR_CONTAINER_LISTA = "#card-content"
    itens = page.locator(f"{SELETOR_CONTAINER_LISTA} .table-body .table-row")
    qtd_itens = itens.count()

    for linha in linhas:
        idx = linha["linha_index"]
        if idx >= qtd_itens:
            continue
        row_element = itens.nth(idx)
        tem_balao = detectar_se_ha_balao_azul(row_element)
        texto_row = linha["texto_row"]
        celulas = linha["celulas"]
        aux = linha["aux"]

        titulo_normalizado = normalizar_texto(aux.get("titulo", ""))
        depto_encontrado = ""
        servico_encontrado = ""
        casou_com_csv = False

        for (depto_norm, serv_norm), dados in base_servicos.items():
            if serv_norm and serv_norm in titulo_normalizado:
                depto_encontrado = dados["Departamento"]
                servico_encontrado = dados["Servico"]
                casou_com_csv = True
                break

        if not tem_balao:
            registro = {
                "Dia_verificado": data_do_dia_str,
                "Departamento (CSV)": depto_encontrado,
                "Servico (CSV)": servico_encontrado,
                "Servico_casado_com_CSV": casou_com_csv,
                "Linha completa (site)": texto_row,
                "Data principal (linha Tareffa)": aux.get("data_principal", ""),
                "Competencia detectada": aux.get("competencia", ""),
                "Documento detectado (CNPJ/CPF)": aux.get("documento", ""),
                "Responsavel (linha Tareffa)": aux.get("responsavel", ""),
                "Titulo detectado (linha Tareffa)": aux.get("titulo", ""),
            }
            inconsistencias.append(registro)

    return inconsistencias


# =====================================================
# FLUXO PRINCIPAL POR DIA/SERVIÇO
# =====================================================


def processar_dia(page, data_obj, base_servicos, df_controle, df_dias, todas_inconsistencias):
    data_str = data_obj.strftime("%Y-%m-%d")
    data_brasil_str = formatar_data_brasileira(data_obj)
    escrever_log(f"Iniciando processamento do dia {data_brasil_str} ({data_str})")

    df_controle = marcar_dia_status(
        df_controle,
        data_str,
        "EM_ANDAMENTO",
        observacao="Início de processamento do dia.",
    )

    limpar_filtro_data(page)
    aplicar_filtro_data(page, data_brasil_str)
    limpar_filtro_servico(page)

    linhas, linhas_incons_depto, fim_confirmado = carregar_todos_registros_lista(page)

    if not linhas and not fim_confirmado:
        escrever_log(
            f"Nenhuma linha foi carregada para a data {data_brasil_str}, "
            "e o fim da lista não foi confirmado. Pode ser problema de carregamento."
        )
        df_controle = marcar_dia_status(
            df_controle,
            data_str,
            "ERRO_CARREGAMENTO",
            observacao="Nenhuma linha carregada e fim não confirmado.",
        )
        df_dias.loc[len(df_dias)] = {
            "Data": data_str,
            "Data_Brasil": data_brasil_str,
            "Status_final": "ERRO_CARREGAMENTO",
            "Qtd_inconsistencias": 0,
        }
        return df_controle, df_dias, todas_inconsistencias

    inconsistencias_dia = verificar_baloes_nas_linhas(page, linhas, base_servicos, data_brasil_str)
    qtd_incons = len(inconsistencias_dia)
    escrever_log(
        f"Dia {data_brasil_str} verificou {len(linhas)} linhas; "
        f"inconsistências detectadas (sem balão azul): {qtd_incons}"
    )

    todas_inconsistencias.extend(inconsistencias_dia)

    status_final_dia = "CONCLUIDO_SEM_INCONSISTENCIA" if qtd_incons == 0 else "COM_INCONSISTENCIA"
    df_controle = marcar_dia_status(
        df_controle,
        data_str,
        status_final_dia,
        observacao=f"Inconsistências detectadas: {qtd_incons}",
    )

    df_dias.loc[len(df_dias)] = {
        "Data": data_str,
        "Data_Brasil": data_brasil_str,
        "Status_final": status_final_dia,
        "Qtd_inconsistencias": qtd_incons,
    }

    return df_controle, df_dias, todas_inconsistencias


