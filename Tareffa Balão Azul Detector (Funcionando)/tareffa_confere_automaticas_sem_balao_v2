# FUNÇÃO PRINCIPAL (MAIN)
# =====================================================


def main():
    base_servicos = carregar_base_servicos(CAMINHO_CSV_SERVICOS)
    escrever_log(f"Base de serviços carregada: {len(base_servicos)} combinações depto/serviço.")

    caminho_controle = os.path.join(PASTA_SAIDA, NOME_ARQ_DIAS_PROCESSADOS)
    df_controle = ler_arquivo_controle_dias(caminho_controle)

    lista_datas = gerar_lista_datas_para_verificar(dias_atras=15)
    df_controle = atualizar_controle_para_datas(df_controle, lista_datas)

    df_dias = pd.DataFrame(
        columns=["Data", "Data_Brasil", "Status_final", "Qtd_inconsistencias"]
    )

    caminho_saida = os.path.join(PASTA_SAIDA, NOME_ARQ_INCONSISTENCIAS)
    df_incons_existente = None
    if os.path.exists(caminho_saida):
        try:
            df_incons_existente = pd.read_excel(caminho_saida, dtype=str).fillna("")
            escrever_log(
                f"Arquivo de inconsistências anterior carregado com "
                f"{len(df_incons_existente)} linhas."
            )
        except Exception as e:
            escrever_log(f"Não foi possível carregar o arquivo de inconsistências anterior: {e}")

    todas_inconsistencias = []
    if df_incons_existente is not None and not df_incons_existente.empty:
        for _, row in df_incons_existente.iterrows():
            todas_inconsistencias.append(row.to_dict())

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=False)
        context = browser.new_context()
        page = context.new_page()

        try:
            fazer_login(page)
            ir_para_lista_servicos(page)
            aplicar_filtros_iniciais(page)

            for data_obj in lista_datas:
                data_str = data_obj.strftime("%Y-%m-%d")
                linha_controle = df_controle[df_controle["Data"].astype(str) == data_str]
                if not linha_controle.empty:
                    status_atual = linha_controle.iloc[0]["Status"]
                    if status_atual in ["CONCLUIDO_SEM_INCONSISTENCIA", "COM_INCONSISTENCIA"]:
                        escrever_log(
                            f"Dia {data_str} já está com status final '{status_atual}', pulando..."
                        )
                        continue

                df_controle, df_dias, todas_inconsistencias = processar_dia(
                    page,
                    data_obj,
                    base_servicos,
                    df_controle,
                    df_dias,
                    todas_inconsistencias,
                )

        finally:
            browser.close()

    # Salva controle final de dias
    df_controle.to_excel(caminho_controle, index=False)
    print(f"Arquivo de controle FINAL atualizado: {caminho_controle}")

    # Lista resumida só dos dias que tiveram inconsistência
    caminho_lista_incons = os.path.join(PASTA_SAIDA, "Lista serviços com inconsistência.xlsx")
    df_incons = df_controle[df_controle["Status"] == "COM_INCONSISTENCIA"].copy()
    if not df_incons.empty:
        df_incons.to_excel(caminho_lista_incons, index=False)
        print(f"Lista FINAL de serviços com inconsistência salva em: {caminho_lista_incons}")
    else:
        print("Nenhum serviço ficou marcado como 'COM INCONSISTENCIA' neste intervalo.")

    # Planilha principal, enxuta, com as inconsistências linha a linha
    salvar_excel_inconsistencias(todas_inconsistencias, caminho_saida)

    # Resumo dos dias processados (arquivo separado)
    caminho_dias_processados = os.path.join(PASTA_SAIDA, NOME_ARQ_DIAS_PROCESSADOS)
    salvar_dias_processados(df_dias, caminho_dias_processados)


if __name__ == "__main__":
    main()